    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://sheets.googleapis.com/v4/spreadsheets/10otVSFr4bp9rtxCpRZGY9Y-8aEqDBMMBn1nvZRq5HCw/values/' + encodeURIComponent(\"'\" + $('Loop Over Channels').item.json.brand + ' - @' + $('Loop Over Channels').item.json.handle + \"'\") + ':append?valueInputOption=USER_ENTERED&insertDataOption=INSERT_ROWS' }}",
        "authentication": "predefinedCredentialType",
