    {
      "parameters": {
        "url": "https://YOUR-PROJECT-REF.supabase.co/rest/v1/handles?platform=eq.instagram&status=eq.approved&select=id,competitor_id,handle,competitors(name)&order=created_at.asc",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "PASTE_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE"
            },
            {
              "name": "Authorization",
              "value": "Bearer PASTE_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE"
            }
          ]
        },
        "options": {}
      },
      "id": "ig08-0001-4f7a-8b1c-000000000004",
      "name": "Fetch IG Handles",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        480,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nlet rows = [];\n\nif (allItems.length === 1 && Array.isArray(allItems[0].json)) {\n  rows = allItems[0].json;\n} else {\n  rows = allItems.map(i => i.json);\n}\n\nif (!rows.length) {\n  throw new Error('No Instagram handles found in Supabase.');\n}\n\nconst SUPABASE_URL = 'https://YOUR-PROJECT-REF.supabase.co';\nconst SUPABASE_KEY = 'PASTE_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE';\n\nconst todo = [];\nlet skipped = 0;\n\nfor (const row of rows) {\n  let check = await this.helpers.httpRequest({\n    method: 'GET',\n    url: `${SUPABASE_URL}/rest/v1/channel_metrics?handle_id=eq.${row.id}&source=eq.socialblade_archive&select=handle_id&limit=1`,\n    headers: {\n      'apikey': SUPABASE_KEY,\n      'Authorization': `Bearer ${SUPABASE_KEY}`\n    }\n  });\n  if (typeof check === 'string') check = JSON.parse(check);\n  if (Array.isArray(check) && check.length > 0) {\n    todo.push(row);\n  } else {\n    skipped++;\n  }\n}\n\nconsole.log(`${rows.length} IG handles total, ${todo.length} have backfill data, ${skipped} skipped (no backfill)`);\n\nif (!todo.length) {\n  throw new Error('No Instagram handles with backfill data found. Run SocialBlade backfill (workflow 07) first.');\n}\n\nreturn todo.map(row => ({\n  json: {\n    handle_id: row.id,\n    competitor_id: row.competitor_id,\n    brand: row.competitors?.name || '',\n    handle: (row.handle || '').replace(/^@/, '')\n  }\n}));"
      },
      "id": "ig08-0001-4f7a-8b1c-000000000005",
      "name": "Filter Backfilled Only",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        352
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "ig08-0001-4f7a-8b1c-000000000006",
      "name": "Loop Over Channels",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        912,
        352
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/apify~instagram-profile-scraper/run-sync-get-dataset-items?token=PASTE_YOUR_APIFY_API_TOKEN_HERE&waitSecs=60",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ usernames: [$json.handle] }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "ig08-0001-4f7a-8b1c-000000000007",
      "name": "Call Apify IG Scraper",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1136,
        448
      ]
    },
    {
      "parameters": {
        "jsCode": "const apifyResponse = $input.item.json;\nconst loopItem = $('Loop Over Channels').item.json;\nconst today = new Date().toISOString().split('T')[0];\n\n// Apify returns an array — get first profile\nconst profile = Array.isArray(apifyResponse) ? apifyResponse[0] : apifyResponse;\n\nif (!profile || !profile.followersCount && profile.followersCount !== 0) {\n  console.log(`${loopItem.brand} (@${loopItem.handle}): Apify returned no data — skipping`);\n  return [{ json: { skip: true, handle_id: loopItem.handle_id, brand: loopItem.brand } }];\n}\n\nconsole.log(`${loopItem.brand} (@${loopItem.handle}): ${profile.followersCount} followers, ${profile.postsCount || 0} posts`);\n\nreturn [{ json: {\n  skip: false,\n  handle_id: loopItem.handle_id,\n  competitor_id: loopItem.competitor_id,\n  brand: loopItem.brand,\n  handle: loopItem.handle,\n  date: today,\n  followers: profile.followersCount || 0,\n  total_posts: profile.postsCount || null,\n  total_views: null,\n  source: 'apify_instagram'\n}}];",
        "mode": "runOnceForEachItem"
      },
      "id": "ig08-0001-4f7a-8b1c-000000000008",
      "name": "Build Metrics Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        448
      ]
    },
    {
      "parameters": {
