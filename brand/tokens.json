{
  "$comment": "Taiyka brand tokens — single source of truth. Web (web/), product PDFs, social assets all consume from here.",
  "color": {
    "primary": {
      "electricBlue": "#00A6FF",
      "cyan":         "#00E5FF",
      "navy":         "#0A1628",
      "white":        "#FFFFFF"
    },
    "neutral": {
      "black":     "#000000",
      "charcoal":  "#0F1A2E",
      "slate":     "#1A2A4A",
      "ink":       "#E8F0FE",
      "muted":     "#8DA2C0"
    },
    "semantic": {
      "success": "#2F9E44",
      "warning": "#F59F00",
      "danger":  "#C92A2A"
    },
    "diagram": {
      "$comment": "Excalidraw stroke/fill pairs — see Main-house/skills/excalidrawer.md",
      "electricBlue": { "stroke": "#1864ab", "fill": "#dbe4ff" },
      "brightBlue":   { "stroke": "#1971c2", "fill": "#74c0fc" },
      "cyanTech":     { "stroke": "#0b7285", "fill": "#e3fafc" },
      "darkNavy":     { "stroke": "#1a2a4a", "fill": "#e8f0fe" },
      "charcoal":     { "stroke": "#343a40", "fill": "#f1f3f5" },
      "success":      { "stroke": "#2f9e44", "fill": "#d3f9d8" },
      "warning":      { "stroke": "#c92a2a", "fill": "#ffe3e3" }
    }
  },
  "gradient": {
    "hero":   "linear-gradient(135deg, #00A6FF 0%, #00E5FF 100%)",
    "navy":   "linear-gradient(180deg, #0A1628 0%, #000000 100%)",
    "glow":   "radial-gradient(circle, rgba(0,166,255,0.35) 0%, rgba(10,22,40,0) 70%)"
  },
  "typography": {
    "fontFamily": {
      "display": "Inter, system-ui, sans-serif",
      "body":    "Inter, system-ui, sans-serif",
      "mono":    "JetBrains Mono, ui-monospace, monospace"
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "black": 900 },
    "$comment": "Inter chosen as default — replace if Manu picks a different display font"
  },
  "radius": { "sm": "6px", "md": "12px", "lg": "20px", "xl": "32px", "full": "9999px" },
  "shadow": {
    "glow":  "0 0 40px rgba(0, 166, 255, 0.35)",
    "card":  "0 8px 24px rgba(0, 0, 0, 0.35)",
    "soft":  "0 2px 8px rgba(0, 0, 0, 0.15)"
  },
  "spacing": { "xs": "4px", "sm": "8px", "md": "16px", "lg": "24px", "xl": "40px", "2xl": "64px" }
}
